{
  "name": "kunterbunt",
  "displayName": "Kunterbunt",
  "description": "Automatically colorize VS Code's title bar, activity bar, and status bar based on the workspace folder name",
  "version": "0.0.1",
  "publisher": "martinus",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "color",
    "workspace",
    "theme",
    "peacock",
    "automatic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/martinus/vscode-extension-kunterbunt"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kunterbunt.apply",
        "title": "Kunterbunt: Apply Colors for This Workspace"
      },
      {
        "command": "kunterbunt.reset",
        "title": "Kunterbunt: Reset Colors for This Workspace"
      }
    ],
    "configuration": {
      "title": "Kunterbunt",
      "properties": {
        "kunterbunt.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically apply workspace colors when a folder is opened."
        },
        "kunterbunt.affectTitleBar": {
          "type": "boolean",
          "default": true,
          "description": "Apply the workspace color to the title bar."
        },
        "kunterbunt.affectActivityBar": {
          "type": "boolean",
          "default": true,
          "description": "Apply the workspace color to the activity bar."
        },
        "kunterbunt.affectStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Apply the workspace color to the status bar."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "mocha --require ts-node/register 'src/test/**/*.test.ts'"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.5",
    "@types/vscode": "^1.85.0",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3"
  }
}
